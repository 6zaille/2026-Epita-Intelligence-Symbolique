# Document OWL-inconsistant : un même individu typé Person ET Organization
# (classes disjointes dans l'ontologie) -> InconsistencyDetected
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dct:  <http://purl.org/dc/terms/> .

<https://example.org/entities/chimera> a foaf:Person, foaf:Organization ;
    foaf:name "Entité Chimère" .

<https://example.org/datasets/test> a dcat:Dataset ;
    dct:title "Jeu de données de test" ;
    dct:publisher <https://example.org/entities/chimera> .
