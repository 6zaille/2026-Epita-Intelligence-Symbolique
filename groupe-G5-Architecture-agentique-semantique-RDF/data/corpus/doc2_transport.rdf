    <rdf:type rdf:resource="http://epita.fr/scia/2026/g5/catalog#PublicBody"/>
  </foaf:Organization>
  <dcat:Distribution rdf:about="https://transport.data.gouv.fr/datasets/gtfs-idf/gtfs.zip">
