         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:dcat="http://www.w3.org/ns/dcat#"
         xmlns:dct="http://purl.org/dc/terms/"
         xmlns:foaf="http://xmlns.com/foaf/0.1/"
         xmlns:ex="http://epita.fr/scia/2026/g5/catalog#">
  <dcat:Dataset rdf:about="https://transport.data.gouv.fr/datasets/gtfs-idf">
    <dct:title xml:lang="fr">Horaires théoriques des transports en Île-de-France</dct:title>
    <dct:publisher rdf:resource="https://www.data.gouv.fr/fr/organizations/ile-de-france-mobilites"/>
